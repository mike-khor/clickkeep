# deps
node_modules/
.pnpm-store/

# build outputs
dist/
build/
.turbo/
*.tsbuildinfo

# env / secrets — NEVER commit
.env
.env.*
!.env.example
.dev.vars
.wrangler/

# editor / OS
.DS_Store
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/

# logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*

# cloudflare local state
.mf/
.miniflare/

# coverage / test
coverage/
apps/web/test-results/
apps/web/playwright-report/
apps/web/.playwright/

# claude worktrees (managed by harness)
.claude/worktrees/

# --- Tooling caches (local-only agent + MCP state) ---
# Claude Code scheduler lockfile — holds a live PID for this machine.
.claude/scheduled_tasks.lock
# Per-user Claude Code permission overrides (settings.json is shared; .local.json is not).
.claude/settings.local.json
# Playwright-MCP console dumps and screenshots from ad-hoc browser runs.
.playwright-mcp/
