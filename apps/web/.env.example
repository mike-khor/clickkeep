# URL of the session worker. In dev, default to local wrangler. In prod, point to the
# deployed worker (e.g. https://clickkeep-session.your-subdomain.workers.dev).
VITE_SESSION_WORKER_URL=http://localhost:8787

# Testing group mode from a phone or other device on the same LAN?
#
# The Vite dev server binds to all interfaces already (`host: true`), but the
# session worker binds to loopback (127.0.0.1) by default — safe on shared
# Wi-Fi, since session ownership is implicit and an unauthenticated worker on
# the LAN would let any nearby device interfere with rehearsals.
#
# To opt in to LAN binding for the worker, run `pnpm worker:dev:lan` instead
# of `pnpm worker:dev`. Then, in a gitignored `.env.local` (never commit real
# IPs here), point the web client at your Mac's LAN IP, e.g.:
#   VITE_SESSION_WORKER_URL=http://192.168.1.42:8787
# Find your Mac's LAN IP with `ipconfig getifaddr en0` (or similar).
