# URL of the session worker. In dev, default to local wrangler. In prod, point to the
# deployed worker (e.g. https://clickkeep-session.your-subdomain.workers.dev).
VITE_SESSION_WORKER_URL=http://localhost:8787

# Testing group mode from a phone or other device on the same LAN? The Vite
# dev server already binds to all interfaces (`host: true`), but the worker
# defaults to loopback-only. wrangler.toml sets `[dev] ip = "0.0.0.0"` so the
# worker also listens on your LAN IP. Then, in a gitignored `.env.local`
# (never commit real IPs here), point the web client at that IP instead of
# localhost, e.g.:
#   VITE_SESSION_WORKER_URL=http://192.168.1.42:8787
# Find your Mac's LAN IP with `ipconfig getifaddr en0` (or similar).
